{
    "name": "rural-lease/portal",
    "description": "Rural Land Lease & Settlement Management Portal",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "topthink/framework": "^6.1",
        "topthink/think-orm": "^2.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "topthink/think-installer": true
        },
        "audit": {
            "block-insecure": false
        }
    }
}
